# Contact form (Resend) — copy to .env.local and fill in.
# Get a free API key at https://resend.com
RESEND_API_KEY=

# Where contact submissions are delivered. Defaults to the profile email if unset.
CONTACT_TO_EMAIL=selwyn.cybersec@gmail.com

# Verified sender. Until you verify a domain in Resend, you can use onboarding@resend.dev.
CONTACT_FROM_EMAIL=onboarding@resend.dev
