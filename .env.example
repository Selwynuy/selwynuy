# Copy to .env.local and fill in. Never commit .env.local.

# Canonical site URL (production). Used for metadata, sitemap, and the one-drop
# CopyForAI / llms.txt absolute links. On Vercel the deploy URL is used if unset.
NEXT_PUBLIC_SITE_URL=https://selwynuy.dev

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Analytics is a no-op
# until this is set, so dev and previews stay clean.
NEXT_PUBLIC_GA_ID=

# Contact form (Resend). Get a free API key at https://resend.com
RESEND_API_KEY=

# Where contact submissions are delivered. Defaults to the profile email if unset.
CONTACT_TO_EMAIL=selwyn.cybersec@gmail.com

# Verified sender. Until you verify a domain in Resend, you can use onboarding@resend.dev.
CONTACT_FROM_EMAIL=onboarding@resend.dev
